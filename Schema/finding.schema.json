{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/princetonafeezx/Log-Parser/blob/main/Schema/finding.schema.json",
  "title": "Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "severity",
    "category",
    "line",
    "ip",
    "message"
  ],
  "properties": {
    "severity": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "info"
      ]
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "line": {
      "type": "integer",
      "minimum": 1
    },
    "ip": {
      "type": "string"
    },
    "message": {
      "type": "string",
      "minLength": 1
    }
  }
}
